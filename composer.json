{
    "name": "stoneshop/bedrock",
    "type": "project",
    "license": "MIT",
    "description": "StoneShop WooCommerce site",
    "require": {
        "php": ">=8.2",
        "composer/installers": "^2.2",
        "vlucas/phpdotenv": "^5.6",
        "oscarotero/env": "^2.1",
        "roots/bedrock-autoloader": "^1.0",
        "roots/bedrock-disallow-indexing": "^2.0",
        "roots/wordpress": "^6.7",
        "roots/wp-config": "^1.0",
        "wpackagist-plugin/woocommerce": "^10.3",
        "wpackagist-plugin/redis-cache": "^2.5",
        "wpackagist-plugin/wordfence": "^8.1",
        "wpackagist-plugin/two-factor": "^0.15",
        "wpackagist-plugin/wps-hide-login": "^1.9",
        "wpackagist-plugin/wp-piwik": "^1.1",
        "wpackagist-plugin/google-listings-and-ads": "^3.5",
        "wpackagist-plugin/pinterest-for-woocommerce": "^1.4",
        "wpackagist-plugin/tiktok-for-business": "^1.3",
        "wpackagist-plugin/woocommerce-paypal-payments": "^3.4",
        "wpackagist-plugin/woocommerce-services": "^3.5"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://wpackagist.org",
            "only": ["wpackagist-plugin/*", "wpackagist-theme/*"]
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "composer/installers": true,
            "roots/wordpress-core-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "installer-paths": {
            "web/app/mu-plugins/{$name}/": ["type:wordpress-muplugin"],
            "web/app/plugins/{$name}/": ["type:wordpress-plugin"],
            "web/app/themes/{$name}/": ["type:wordpress-theme"]
        },
        "wordpress-install-dir": "web/wp"
    },
    "scripts": {
        "post-root-package-install": [
            "php -r \"copy('.env.example', '.env');\""
        ]
    }
}
