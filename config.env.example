# Dockbase Configuration
# Copy this file to config.env and fill in real values.
# NEVER commit config.env — it contains secrets.

# ── Deploy Mode ───────────────────────────────────────────
# full = shared infra + shop + mail + website
# shop = shared infra + shop only
# mail = shared infra + mail only
# web  = shared infra + website only
DEPLOY_MODE=full

# ── Server ────────────────────────────────────────────────
SERVER_IP=
TLS_EMAIL=admin@example.com

# ── Shop Domain ───────────────────────────────────────────
SITE_DOMAIN=stoneshop.example.com

# Migration only: set to the previous domain for wp search-replace.
# Remove or leave empty after migration is complete.
OLD_DOMAIN=

# ── Mail ──────────────────────────────────────────────────
MAIL_HOSTNAME=mail.fraefel.de
MAILCOW_API_KEY=

# ── Database ──────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme
MYSQL_DATABASE=stoneshop
MYSQL_USER=stoneshop
MYSQL_PASSWORD=changeme

# Shop Matomo
MATOMO_DATABASE_HOST=mariadb
MATOMO_DATABASE_DBNAME=matomo_shop
MATOMO_DATABASE_USERNAME=matomo_shop
MATOMO_SHOP_DATABASE_PASSWORD=changeme

# Web Matomo
MATOMO_WEB_DATABASE_PASSWORD=changeme

# ── WordPress salts ───────────────────────────────────────
# Generate at https://roots.io/salts.html
AUTH_KEY=
SECURE_AUTH_KEY=
LOGGED_IN_KEY=
NONCE_KEY=
AUTH_SALT=
SECURE_AUTH_SALT=
LOGGED_IN_SALT=
NONCE_SALT=

# ── WP SMTP relay (consumed by web/app/mu-plugins/stoneshop-smtp.php) ──
# Routes wp_mail through Mailcow's submission port. Use a real mailbox
# (not an alias) for SMTP AUTH; From: can be any deliverable address
# (alias OK). Password lives in /opt/mailcow/initial-passwords.txt
# after setup-mailcow.sh runs.
WP_SMTP_HOST=mail.fraefel.de
WP_SMTP_PORT=587
WP_SMTP_USER=info@stoneshop.de
WP_SMTP_PASS=
WP_SMTP_FROM_EMAIL=bestellungen@stoneshop.de
WP_SMTP_FROM_NAME=StoneShop
WP_SMTP_ENCRYPTION=tls

# ── Restic backup ─────────────────────────────────────────
RESTIC_REPOSITORY=sftp:storagebox:backups/dockbase
RESTIC_PASSWORD=changeme

# Healthchecks.io heartbeat for nightly backup (optional).
# Leave empty to disable. URL form:
#   https://hc-ping.com/<uuid>
# backup.sh pings ${URL}/start at begin, bare ${URL} on success,
# and ${URL}/fail (with log tail) on error.
HEALTHCHECKS_BACKUP_URL=

# ── StorageBox (backup target) ────────────────────────────
STORAGEBOX_HOST=uXXXXXX.your-storagebox.de
STORAGEBOX_USER=uXXXXXX
STORAGEBOX_PORT=23

# ── CrowdSec (optional) ──────────────────────────────────
CROWDSEC_ENROLL_KEY=
