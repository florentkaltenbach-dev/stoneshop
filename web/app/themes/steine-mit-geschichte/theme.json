{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "980px",
			"wideSize": "1400px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "bg-primary",
					"color": "#f8f7f4",
					"name": "Background"
				},
				{
					"slug": "bg-secondary",
					"color": "#f3f2ef",
					"name": "Background Secondary"
				},
				{
					"slug": "bg-tertiary",
					"color": "#eceae6",
					"name": "Background Tertiary"
				},
				{
					"slug": "text-primary",
					"color": "#2c2c2c",
					"name": "Text"
				},
				{
					"slug": "text-secondary",
					"color": "#5a5a5a",
					"name": "Text Secondary"
				},
				{
					"slug": "text-muted",
					"color": "#7a7a7a",
					"name": "Text Muted"
				},
				{
					"slug": "accent",
					"color": "#6b7c6b",
					"name": "Accent (Sage)"
				},
				{
					"slug": "accent-hover",
					"color": "#5a6b5a",
					"name": "Accent Hover"
				},
				{
					"slug": "border",
					"color": "#d4d2cd",
					"name": "Border"
				},
				{
					"slug": "border-light",
					"color": "#e5e3de",
					"name": "Border Light"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "\"Cinzel\", Georgia, serif",
					"slug": "heading",
					"name": "Heading (Cinzel)"
				},
				{
					"fontFamily": "\"EB Garamond\", Garamond, Georgia, serif",
					"slug": "body",
					"name": "Body (EB Garamond)"
				}
			],
			"fontSizes": [
				{
					"slug": "xs",
					"size": "0.875rem",
					"name": "Extra Small"
				},
				{
					"slug": "small",
					"size": "1rem",
					"name": "Small"
				},
				{
					"slug": "medium",
					"size": "1.125rem",
					"name": "Medium (Body)"
				},
				{
					"slug": "large",
					"size": "1.5rem",
					"name": "Large"
				},
				{
					"slug": "x-large",
					"size": "2rem",
					"name": "Extra Large"
				},
				{
					"slug": "xx-large",
					"size": "2.5rem",
					"name": "XX Large"
				}
			]
		},
		"spacing": {
			"units": [ "px", "rem", "em", "%" ],
			"spacingSizes": [
				{
					"slug": "10",
					"size": "0.25rem",
					"name": "3XS (4px)"
				},
				{
					"slug": "20",
					"size": "0.5rem",
					"name": "2XS (8px)"
				},
				{
					"slug": "30",
					"size": "0.75rem",
					"name": "XS (12px)"
				},
				{
					"slug": "40",
					"size": "1rem",
					"name": "SM (16px)"
				},
				{
					"slug": "50",
					"size": "1.5rem",
					"name": "MD (24px)"
				},
				{
					"slug": "60",
					"size": "2rem",
					"name": "LG (32px)"
				},
				{
					"slug": "70",
					"size": "3rem",
					"name": "XL (48px)"
				},
				{
					"slug": "80",
					"size": "4rem",
					"name": "2XL (64px)"
				}
			]
		},
		"useRootPaddingAwareAlignments": true,
		"blocks": {
			"core/button": {
				"border": {
					"radius": false
				}
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--color-bg-primary, #f8f7f4)",
			"text": "var(--color-text-primary, #2c2c2c)"
		},
		"typography": {
			"fontFamily": "var(--font-primary, '\"EB Garamond\", Garamond, Georgia, serif')",
			"fontSize": "var(--font-size-base, 1.125rem)",
			"lineHeight": "1.6"
		},
		"spacing": {
			"padding": {
				"left": "var(--pad-x, clamp(16px, 4vw, 56px))",
				"right": "var(--pad-x, clamp(16px, 4vw, 56px))"
			}
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--color-accent, #6b7c6b)"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--font-heading, '\"Cinzel\", Georgia, serif')",
					"fontWeight": "normal",
					"lineHeight": "1.2"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--font-size-xl, 2.5rem)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--font-size-lg, 2rem)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--font-size-md, 1.5rem)"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "front-page",
			"title": "Front Page",
			"postTypes": [ "page" ]
		}
	]
}
